{
  "name": "devbrief",
  "version": "0.1.0",
  "description": "AI agent that monitors your library stack, scrapes changelogs daily, and delivers a concise voice briefing on what changed.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "devbrief": "dist/cli/index.js",
    "devbrief-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "axios": "^1.15.2",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "fluent-ffmpeg": "^2.1.3",
    "groq-sdk": "^1.1.2",
    "hono": "^4.12.16",
    "mastra": "^1.7.2",
    "@mastra/core": "^1.30.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "olostep": "^1.0.0",
    "p-limit": "^7.3.0",
    "uuid": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "fast-check": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
