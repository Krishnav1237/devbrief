# ============================================================================
# DevBrief Legacy Pipeline Environment Variables
# ============================================================================
# Copy this file to your root .env if you are using the legacy briefing
# pipeline (devbrief run, POST /trigger, and text-to-speech recordings).
#
# These are NOT required for the core npx devbrief doctor maintenance scanner.
# ============================================================================

# --- LLM Provider (at least one required) ---
# Used to classify and summarize scraped release notes.
GROQ_API_KEY=
OLLAMA_BASE_URL=
GROQ_MODEL=

# --- Web Scraping (required) ---
# Olostep fetches and renders changelog pages.
OLOSTEP_API_KEY=

# --- Text-to-Speech (required) ---
# Sarvam AI converts script into spoken MP3 recordings.
SARVAM_API_KEY=

# --- Cloud Storage (optional) ---
# HydraDB cloud deduplication storage.
HYDRADB_API_KEY=
HYDRADB_TENANT_ID=

# --- Cron Scheduling (optional) ---
# Triggers automated pipeline runs.
DEVBRIEF_CRON="0 7 * * *"
TZ=

# --- SMTP Email Notifications (optional) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- Discord Notifications (optional) ---
DISCORD_WEBHOOK_URL=
