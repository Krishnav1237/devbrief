# ============================================================================
# DevBrief Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
#
# DevBrief is a pipeline that:
#   1. Scrapes changelogs from your tracked libraries (Olostep)
#   2. Classifies and summarizes changes using an LLM (Groq or Ollama)
#   3. Generates a voice briefing (Sarvam AI)
#   4. Serves the digest over your Tailscale network
#   5. Notifies you via webhook, Discord, or email
#
# MINIMUM REQUIRED: GROQ_API_KEY (or OLLAMA_BASE_URL), OLOSTEP_API_KEY, SARVAM_API_KEY
# ============================================================================


# --- LLM Provider (at least one required) ---
# Used by the Summarizer step to classify changes as breaking/deprecation/feature/patch
# and generate plain-language summaries.
#
# Option A: Groq (recommended for speed — free tier: 30 req/min on Llama 3 8B)
#   Sign up: https://console.groq.com/keys
GROQ_API_KEY=

# Option B: Ollama (local, no API key needed, but requires Ollama running locally)
#   Install: https://ollama.ai → then run: ollama pull llama3
#   If both are set, Groq is preferred.
OLLAMA_BASE_URL=


# --- Web Scraping (required) ---
# Olostep fetches and renders changelog pages as clean markdown.
# Used by the Scraper step to pull content from GitHub releases, docs, etc.
#   Sign up: https://www.olostep.com/ → Dashboard → API Keys
#   Free tier: 100 scrapes/month
OLOSTEP_API_KEY=


# --- Text-to-Speech (required) ---
# Sarvam AI converts the briefing script into a spoken MP3 audio file.
# Uses the Bulbul V3 model with the "arvind" English-India voice.
#   Sign up: https://www.sarvam.ai/ → Dashboard → API Keys
#   Free tier: limited requests/day
SARVAM_API_KEY=


# --- Publishing (not used currently) ---
# Paperclip turned out to be a project management API, not a file-hosting service.
# DevBrief uses local file hosting over Tailscale instead (GET /digest/:run_id).
# This variable is kept for future use if a publishing integration is added.
PAPERCLIP_API_KEY=


# --- HydraDB (optional) ---
# HydraDB provides persistent cloud storage for change entries and run summaries,
# enabling semantic recall and multi-device deduplication.
# If not set, DevBrief uses SQLite-only mode (fully functional, just local).
#   Sign up: https://docs.usecortex.ai → Dashboard → API Keys
HYDRADB_API_KEY=
HYDRADB_TENANT_ID=


# --- HTTP Server (optional) ---
# The server binds to your Tailscale IP so it's only accessible on your tailnet.
# If TAILSCALE_IP is not set, DevBrief auto-detects the first 100.x.x.x interface.
# If you're not on Tailscale, it falls back to 0.0.0.0 (all interfaces).
TAILSCALE_IP=
DEVBRIEF_PORT=7890


# --- Cron Scheduling (optional) ---
# When the server is running, it triggers the pipeline on this schedule.
# Default: 7 AM daily. Uses standard cron syntax (minute hour day month weekday).
# The timezone is your system's local timezone unless TZ is set.
DEVBRIEF_CRON="0 7 * * *"
TZ=


# --- Email Notifications (optional) ---
# Only needed if you add an "email" channel to ~/.devbrief/notification-config.json.
# Works with any SMTP provider (Gmail, SendGrid, Mailgun, etc.)
# For Gmail: use an App Password, not your regular password.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=


# --- Discord Notifications (optional) ---
# Only needed if you add a "discord" channel to ~/.devbrief/notification-config.json.
# Create a webhook: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=
