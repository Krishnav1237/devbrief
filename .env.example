# ============================================================================
# DevBrief Environment Variables (Optional Server Settings Only)
# ============================================================================
# Core DevBrief CLI commands (npx devbrief doctor) require ZERO environment
# variables and run fully locally out of the box.
#
# Only copy this file to .env if you wish to run the optional local HTTP server
# and dashboard and want to customize the port or Tailscale IP.
# ============================================================================

# The port to bind the local dashboard server to.
DEVBRIEF_PORT=7890

# Optional Tailscale IP bind override.
# DevBrief automatically detects the first 100.x.x.x Tailscale interface
# and binds to it. Set this if you wish to override the bind IP.
TAILSCALE_IP=
